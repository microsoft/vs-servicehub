		"jshint": "2.13.6",
		"nerdbank-gitversioning": "3.9.50",
		"nyc": "18.0.0",
		"prettier": "3.8.3",
		"ts-jest": "29.4.11",
		"ts-node": "10.9.2",
		"typescript": "6.0.3",
		"typescript-eslint": "8.60.1",
		"yargs": "18.0.0"
